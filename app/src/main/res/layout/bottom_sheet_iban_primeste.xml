<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A2E4A"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="24dp"
    android:paddingTop="12dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:background="#7A9CC0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <!-- Titlu -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IBAN-ul tau"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Copiaza sau distribuie"
        android:textColor="#7A9CC0"
        android:textSize="11sp"
        android:layout_marginBottom="16dp"/>

    <!-- Card indicator -->
    <LinearLayout
        android:id="@+id/layoutCardIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/tvNumeBancaIban"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BCR"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvNumarCardIban"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="•••• 3377 — 5,230.00 RON"
            android:textColor="@android:color/white"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- IBAN display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#12203A"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IBAN"
            android:textColor="#7A9CC0"
            android:textSize="10sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvIbanComplet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RO49 AAAA 1B31 0075 9384 0000"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvTitularIban"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Titular: Ioana Stefania"
            android:textColor="#7A9CC0"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- Butoane Copiaza + Distribuie -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:id="@+id/btnCopiazaIban"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="#1A3C6E"
            android:orientation="horizontal"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copiaza"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnDistribuieIban"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:background="#1A3C6E"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distribuie"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Inchide -->
    <LinearLayout
        android:id="@+id/btnInchideIban"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="#12203A"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inchide"
            android:textColor="#E53935"
            android:textSize="13sp"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>