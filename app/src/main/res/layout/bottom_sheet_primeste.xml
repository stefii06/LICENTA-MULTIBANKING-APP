<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A2E4A"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="24dp"
    android:paddingTop="12dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:background="#7A9CC0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <!-- Titlu -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Primeste bani"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <!-- Label slider -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alege contul"
        android:textColor="#7A9CC0"
        android:textSize="11sp"
        android:layout_marginBottom="8dp"/>

    <!-- Slider carduri -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCarduriPrimeste"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:clipToPadding="false"
        android:layout_marginBottom="20dp"/>

    <!-- Optiunea IBAN -->
    <LinearLayout
        android:id="@+id/optionIbanPrimeste"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#12203A"
        android:padding="14dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:text="IB"
            android:textColor="#B0C8F0"
            android:textSize="12sp"
            android:background="#1A3C6E"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IBAN"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copiaza sau distribuie IBAN-ul"
                android:textColor="#7A9CC0"
                android:textSize="11sp"/>

        </LinearLayout>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_transactions"/>

    </LinearLayout>

    <!-- Optiunea QR -->
    <LinearLayout
        android:id="@+id/optionQRPrimeste"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#12203A"
        android:padding="14dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:text="QR"
            android:textColor="#B0C8F0"
            android:textSize="12sp"
            android:background="#1A3C6E"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cod QR"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Altcineva scaneaza QR-ul tau"
                android:textColor="#7A9CC0"
                android:textSize="11sp"/>

        </LinearLayout>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_transactions"/>

    </LinearLayout>

    <!-- Anuleaza -->
    <LinearLayout
        android:id="@+id/optionAnuleazaPrimeste"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="#12203A"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anuleaza"
            android:textColor="#E53935"
            android:textSize="13sp"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>