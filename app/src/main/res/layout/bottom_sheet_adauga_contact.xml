<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A2E4A"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:background="#7A9CC0"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- Titlu -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Adauga contact"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nume"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#4A90D9"
            app:hintTextColor="#7A9CC0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNumeContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textPersonName"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Prenume"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#4A90D9"
            app:hintTextColor="#7A9CC0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrenumeContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textPersonName"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IBAN"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#4A90D9"
            app:hintTextColor="#7A9CC0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etIbanContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textCapCharacters"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nota (optional)"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#4A90D9"
            app:hintTextColor="#7A9CC0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotaContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="text"/>

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSalveazaContact"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Salveaza contact"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A90D9"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAnuleazaContact"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Anuleaza"
            android:textColor="#E53935"
            android:backgroundTint="#12203A"/>

    </LinearLayout>

</LinearLayout>