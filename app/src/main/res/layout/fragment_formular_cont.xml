<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A2E4A"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:background="#7A9CC0"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="0dp"/>

    <!-- Header cu culoarea bancii -->
    <TextView
        android:id="@+id/tvNumeBancaFormular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Conectare BCR"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilIban"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IBAN"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#4A90D9"
            app:hintTextColor="#7A9CC0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etIbanFormular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textCapCharacters"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTitular"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titular cont"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="#4A90D9"
            app:hintTextColor="#7A9CC0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitularFormular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textPersonName"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSold"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Sold initial (RON)"
            android:layout_marginBottom="24dp"
            app:boxStrokeColor="#4A90D9"
            app:hintTextColor="#7A9CC0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSoldFormular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="numberDecimal"/>

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnConecteaza"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Conecteaza cont"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A90D9"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnAnuleazaFormular"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Anuleaza"
            android:textColor="#E53935"
            android:backgroundTint="#12203A"/>

    </LinearLayout>

</LinearLayout>