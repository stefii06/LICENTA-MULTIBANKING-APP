<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12203A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="IS"
                android:textColor="#B0C8F0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="#1A3C6E"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bună ziua,"
                    android:textColor="#7A9CC0"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ioana Stefania"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/ivNotifications"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_profile"
                android:padding="6dp"
                android:background="#1A3C6E"/>

        </LinearLayout>

        <!-- Card sold + peek -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <!-- Peek verde -->
            <LinearLayout
                android:id="@+id/layoutCardPeek"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:background="#4CAF50"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <ImageView
                    android:id="@+id/ivCardArrow"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_statistics"/>

            </LinearLayout>

            <!-- Cardul revelat -->
            <LinearLayout
                android:id="@+id/layoutCardRevelat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#2E7D32"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BCR — Visa Debit"
                    android:textColor="#B0F0B0"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="•••• •••• •••• 3377"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Expiră"
                            android:textColor="#B0F0B0"
                            android:textSize="10sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="08/27"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VISA"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Butoane contextuale card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/btnDetaliuCard"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_card"
                            android:background="#1A5C1A"
                            android:padding="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Detalii"
                            android:textColor="#B0F0B0"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/btnIngheataCard"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_profile"
                            android:background="#1A5C1A"
                            android:padding="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Îngheață"
                            android:textColor="#B0F0B0"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/btnStergeCard"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_transactions"
                            android:background="#8B0000"
                            android:padding="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Șterge"
                            android:textColor="#FFB0B0"
                            android:textSize="10sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Status inghetat -->
                <TextView
                    android:id="@+id/tvStatusInghetat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Card inghetat — apasa Ingheata pentru a debloca"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:background="#4A90D9"
                    android:padding="8dp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Card sold -->
            <LinearLayout
                android:id="@+id/layoutSold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1A2E4A"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sold Total"
                    android:textColor="#7A9CC0"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvSoldTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5,230.00 RON"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvAlteCurrency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+120.00 EUR  +45.00 USD"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Butoane rapide -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/btnTrimite"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_transactions"
                    android:background="#1A3C6E"
                    android:padding="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trimite"
                    android:textColor="#7A9CC0"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/btnPrimeste"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_transactions"
                    android:background="#1A3C6E"
                    android:padding="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Primește"
                    android:textColor="#7A9CC0"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/btnPlateste"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_card"
                    android:background="#1A3C6E"
                    android:padding="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plătește"
                    android:textColor="#7A9CC0"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/btnAdaugaCont"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_profile"
                    android:background="#1A3C6E"
                    android:padding="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adaugă cont"
                    android:textColor="#7A9CC0"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Contacte recente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Contacte recente"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvVeziToateContacte"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vezi toate"
                    android:textColor="#4A90D9"
                    android:textSize="12sp"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContacte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"/>

        </LinearLayout>

        <!-- Banner tranzactii -->
        <LinearLayout
            android:id="@+id/layoutBannerTranzactii"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A2E4A"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tranzacții"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vezi istoricul complet"
                    android:textColor="#7A9CC0"
                    android:textSize="11sp"/>

            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_transactions"
                android:padding="2dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>