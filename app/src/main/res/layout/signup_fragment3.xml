<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#F0F4FF">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@android:drawable/ic_dialog_email"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verificare număr de telefon"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A3C6E"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvPhoneNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Am trimis un cod SMS la numărul tău"
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <!-- Cele 6 casute OTP -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <EditText
            android:id="@+id/otp1"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:drawable/editbox_background"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/otp2"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:drawable/editbox_background"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/otp3"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:drawable/editbox_background"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/otp4"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:drawable/editbox_background"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/otp5"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:drawable/editbox_background"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/otp6"
            android:layout_width="45dp"
            android:layout_height="55dp"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@android:drawable/editbox_background"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnVerify"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Verifică"
        android:backgroundTint="#1A3C6E"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvResendCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nu ai primit codul? Retrimite"
        android:textColor="#4A90D9"
        android:textSize="14sp"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Înapoi"
        android:backgroundTint="#4A90D9"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="16dp"/>

</LinearLayout>